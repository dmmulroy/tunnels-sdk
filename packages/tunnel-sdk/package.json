{
  "name": "tunnel-sdk",
  "version": "0.1.0",
  "description": "A TypeScript SDK for Cloudflare Tunnels — full lifecycle management with top-notch DX",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./effect": {
      "types": {
        "import": "./dist/effect/index.d.mts",
        "require": "./dist/effect/index.d.cts"
      },
      "import": "./dist/effect/index.mjs",
      "require": "./dist/effect/index.cjs"
    },
    "./bin": {
      "types": {
        "import": "./dist/bin/index.d.mts",
        "require": "./dist/bin/index.d.cts"
      },
      "import": "./dist/bin/index.mjs",
      "require": "./dist/bin/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cloudflare",
    "tunnel",
    "cloudflared",
    "zero-trust",
    "networking"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@effect/platform-node": "beta",
    "effect": "beta",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@effect/vitest": "beta",
    "@types/node": "^25.5.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
