{
  "name": "tunnels-cli",
  "version": "0.1.0",
  "description": "A modern CLI for Cloudflare Tunnels",
  "type": "module",
  "bin": {
    "tunnels": "./dist/bin/tunnels.js"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.42",
    "effect": "4.0.0-beta.42",
    "tunnels": "workspace:*"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.42",
    "@types/node": "^25.5.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
