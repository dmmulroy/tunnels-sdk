# Cloudflare credentials for integration & e2e tests.
# Copy to .env and fill in values.
# The .env file is gitignored — never commit real credentials.

# Required for Tier 2+ tests (API integration)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Required for DNS tests — a zone your token has access to
CFT_TEST_ZONE=
